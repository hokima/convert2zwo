{
  "name": "convert2zwo",
  "version": "1.0.0",
  "description": "Convert workout plans to Zwift .zwo files",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "jsonrepair": "^3.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.convert2zwo.app",
    "productName": "Convert2ZWO",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
